#include <Wire.h>
#include <vl53l4ed_class.h>

constexpr int kXshutPin = -1;  // Ikke bruk XSHUT i denne testen.
constexpr uint8_t kDistanceI2cAddress = 0x29;
constexpr uint32_t kWireTimeoutUs = 25000;
constexpr uint16_t kSignalThresholdKcps = 0;
constexpr int kOffsetMm = 15;
constexpr unsigned long kRetryPeriodMs = 2000;

VL53L4ED sensor(&Wire, kXshutPin);

bool sensor_ready = false;
unsigned long last_init_attempt_ms = 0;

bool i2c_device_present(uint8_t address) {
  Wire.beginTransmission(address);
  return Wire.endTransmission() == 0;
}

void print_i2c_scan() {
  Serial.println("I2C scan begin");
  bool found_any = false;
  for (uint8_t address = 1; address < 127; address++) {
    Wire.beginTransmission(address);
    const uint8_t error = Wire.endTransmission();
    if (error == 0) {
      found_any = true;
      Serial.print("I2C device 0x");
      if (address < 16) {
        Serial.print("0");
      }
      Serial.println(address, HEX);
    }
  }
  if (!found_any) {
    Serial.println("I2C scan none");
  }
  Serial.println("I2C scan end");
}

bool init_distance_sensor() {
  Serial.println("DIST INIT begin");

  if (!i2c_device_present(kDistanceI2cAddress)) {
    Serial.println("ERR DIST I2C 0x29 not found");
    print_i2c_scan();
    return false;
  }

  int status = sensor.begin();
  if (status != 0) {
    Serial.print("ERR DIST BEGIN ");
    Serial.println(status);
    return false;
  }

  status = sensor.InitSensor();
  if (status != 0) {
    Serial.print("ERR DIST INIT ");
    Serial.println(status);
    return false;
  }

  status = sensor.VL53L4ED_SetSignalThreshold(kSignalThresholdKcps);
  if (status != 0) {
    Serial.print("ERR DIST SIGNAL_THRESHOLD ");
    Serial.println(status);
    return false;
  }

  status = sensor.VL53L4ED_StartRanging();
  if (status != 0) {
    Serial.print("ERR DIST START ");
    Serial.println(status);
    return false;
  }

  Serial.println("OK DIST INIT");
  return true;
}

void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println("VL53L4ED distance test, no XSHUT");
  Serial.println("Mega I2C: SDA=20 SCL=21");

  Wire.begin();
  Wire.setClock(100000);
  Wire.setWireTimeout(kWireTimeoutUs, true);
  delay(50);

  sensor_ready = init_distance_sensor();
  last_init_attempt_ms = millis();
}

void loop() {
  if (!sensor_ready) {
    if (millis() - last_init_attempt_ms >= kRetryPeriodMs) {
      last_init_attempt_ms = millis();
      sensor_ready = init_distance_sensor();
    }
    return;
  }

  uint8_t data_ready = 0;
  int status = sensor.VL53L4ED_CheckForDataReady(&data_ready);
  if (status != 0) {
    Serial.print("ERR DIST READY ");
    Serial.println(status);
    sensor_ready = false;
    return;
  }

  if (!data_ready) {
    delay(20);
    return;
  }

  VL53L4ED_ResultsData_t result;
  sensor.VL53L4ED_ClearInterrupt();
  status = sensor.VL53L4ED_GetResult(&result);
  if (status != 0) {
    Serial.print("ERR DIST RESULT ");
    Serial.println(status);
    sensor_ready = false;
    return;
  }

  const int raw_distance_mm = result.distance_mm;
  const bool valid_distance = result.range_status == 0 && raw_distance_mm > 0;
  const int calibrated_distance_mm = valid_distance ? max(0, raw_distance_mm - kOffsetMm) : -1;

  Serial.print("DIST raw=");
  Serial.print(raw_distance_mm);
  Serial.print(" calibrated=");
  Serial.print(calibrated_distance_mm);
  Serial.print(" status=");
  Serial.print(result.range_status);
  Serial.print(" signal=");
  Serial.print(result.signal_per_spad_kcps);
  Serial.print(" spads=");
  Serial.print(result.number_of_spad);
  Serial.print(" ambient=");
  Serial.print(result.ambient_per_spad_kcps);
  Serial.print(" sigma=");
  Serial.print(result.sigma_mm);
  Serial.print(" valid=");
  Serial.print(valid_distance ? 1 : 0);
  Serial.println(" mm");

  delay(50);
}
