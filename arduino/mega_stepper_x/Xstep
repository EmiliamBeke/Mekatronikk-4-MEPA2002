#include <stdlib.h>
#include <string.h>

#define STEP_PIN 45
#define DIR_PIN 29
#define EN_PIN 37

constexpr long kBaudrate = 115200;
constexpr size_t kMaxCommandLength = 63;
constexpr unsigned int kStepPulseUs = 10;
constexpr unsigned int kStepDelayUs = 1000;
constexpr bool kInvertXDirection = false;

char command_buffer[kMaxCommandLength + 1];
size_t command_length = 0;

void reset_command_buffer() {
  command_length = 0;
  command_buffer[0] = '\0';
}

void move_x_stepper(long steps) {
  if (steps == 0) {
    return;
  }

  const bool positive_direction = steps > 0;
  const bool dir_level = kInvertXDirection ? !positive_direction : positive_direction;
  const long count = labs(steps);

  digitalWrite(DIR_PIN, dir_level ? HIGH : LOW);

  for (long i = 0; i < count; i++) {
    digitalWrite(STEP_PIN, HIGH);
    delayMicroseconds(kStepPulseUs);
    digitalWrite(STEP_PIN, LOW);
    delayMicroseconds(kStepDelayUs);
  }
}

void handle_command(const char *command) {
  if (strcmp(command, "PING") == 0) {
    Serial.println("PONG");
    return;
  }

  if (strcmp(command, "ID") == 0) {
    Serial.println("MEGA_STEPPER_X");
    return;
  }

  if (strcmp(command, "STOP") == 0) {
    Serial.println("OK STOP");
    return;
  }

  long x_steps = 0;
  if (sscanf(command, "ARM X %ld", &x_steps) == 1) {
    Serial.println("OK ARM X");
    move_x_stepper(x_steps);
    return;
  }

  Serial.println("ERR UNKNOWN");
}

void setup() {
  Serial.begin(kBaudrate);
  pinMode(STEP_PIN, OUTPUT);
  pinMode(DIR_PIN, OUTPUT);
  pinMode(EN_PIN, OUTPUT);

  digitalWrite(STEP_PIN, LOW);
  digitalWrite(DIR_PIN, LOW);
  digitalWrite(EN_PIN, LOW);

  reset_command_buffer();
  Serial.println("MEGA_STEPPER_X_READY");
}

void loop() {
  while (Serial.available() > 0) {
    const char c = static_cast<char>(Serial.read());

    if (c == '\r') {
      continue;
    }

    if (c == '\n') {
      command_buffer[command_length] = '\0';
      if (command_length > 0) {
        handle_command(command_buffer);
      }
      reset_command_buffer();
      continue;
    }

    if (command_length < kMaxCommandLength) {
      command_buffer[command_length++] = c;
    }
  }
}
